# ══════════════════════════════════════════════════════════
# Airtable - IDs de Tablas
# ══════════════════════════════════════════════════════════
# Tabla "Personal" — datos de empleados, credenciales, accesos
AIRTABLE_PERSONAL_TABLE_ID=tbl_id_tabla_personal
# Tabla "Sistemas y Aplicaciones" — catálogo de apps corporativas
AIRTABLE_SISTEMAS_TABLE_ID=tbl_id_tabla_sistemas

# ══════════════════════════════════════════════════════════
# Airtable - Field IDs de tabla "Personal"
# ══════════════════════════════════════════════════════════
# Código único del empleado (ej: EMP-001)
AIRTABLE_PF_ID_EMPLEADO=fld_xxx
# URL de la foto de perfil del empleado
AIRTABLE_PF_FOTO_PERFIL=fld_xxx
# Nombre completo del empleado
AIRTABLE_PF_NOMBRE_COMPLETO=fld_xxx
# Tipo de personal (interno, contratista, etc.)
AIRTABLE_PF_TIPO_PERSONAL=fld_xxx
# Rol del empleado en la organización
AIRTABLE_PF_ROL=fld_xxx
# Correo electrónico corporativo
AIRTABLE_PF_CORREO=fld_xxx
AIRTABLE_PF_FECHA_NACIMIENTO=          # Field ID: Fecha de nacimiento (Personal)
AIRTABLE_PF_FECHA_INCORPORACION=      # Field ID: Fecha de incorporación (Personal)
# Número de teléfono de contacto
AIRTABLE_PF_TELEFONO=fld_xxx
# Número de documento de identidad (cédula)
AIRTABLE_PF_NUMERO_DOCUMENTO=fld_xxx
# Hash de la contraseña del empleado
AIRTABLE_PF_PASSWORD=fld_xxx
# IDs de accesos/apps asignadas al empleado (linked records)
AIRTABLE_PF_ACCESOS_ASIGNADOS=fld_xxx
# Estado de actividad del empleado (activo/inactivo)
AIRTABLE_PF_ESTADO_ACTIVIDAD=fld_xxx
# Áreas a las que pertenece el empleado
AIRTABLE_PF_AREAS=fld_xxx


